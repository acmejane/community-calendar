--tec-color-link-accent: #004975;
--tec-color-link-accent-hover: rgba(0,73,117, 0.8);
--tec-color-accent-primary: #004975;
--tec-color-accent-primary-hover: rgba(0,73,117,0.8);
--tec-color-accent-primary-multiday: rgba(0,73,117,0.24);
--tec-color-accent-primary-multiday-hover: rgba(0,73,117,0.34);
--tec-color-accent-primary-active: rgba(0,73,117,0.9);
--tec-color-accent-primary-background: rgba(0,73,117,0.07);
--tec-color-background-secondary-datepicker: rgba(0,73,117,0.5);
--tec-color-accent-primary-background-datepicker: #004975;
--tec-color-button-primary: #004975;
--tec-color-button-primary-hover: rgba(0,73,117,0.8);
--tec-color-button-primary-active: rgba(0,73,117,0.9);
--tec-color-button-primary-background: rgba(0,73,117,0.07);
--tec-color-day-marker-current-month: #004975;
--tec-color-day-marker-current-month-hover: rgba(0,73,117,0.8);
--tec-color-day-marker-current-month-active: rgba(0,73,117,0.9);
--tec-color-background-primary-multiday: rgba(0,73,117, 0.24);
--tec-color-background-primary-multiday-hover: rgba(0,73,117, 0.34);
